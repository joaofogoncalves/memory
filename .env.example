# === LinkedIn Profile URL (required for pipeline.sh) ===
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/your-username

# === LinkedIn API Credentials (required for --auth API path only) ===
# Create an app at https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:8080/callback

# === Website (optional) ===
# Public URL of your deployed site (used for Open Graph tags)
SITE_URL=
# Google Analytics measurement ID
GA_MEASUREMENT_ID=

# === Deployment (optional) ===
# Used by web/deploy.sh — configured for rsync-over-SSH.
# Adapt the variable names and deploy script for your hosting provider.
OPAL_SSH_USER=
OPAL_SSH_HOST=opal1.opalstack.com
OPAL_SSH_PORT=22
OPAL_APP_PATH=/home/your_user/apps/your_app
