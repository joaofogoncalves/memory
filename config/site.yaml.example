# Site personalization — copy to site.yaml and fill in your details.
# All fields are optional; empty values produce a generic site.

# Identity
site_name: "Your Name"
site_description: "A short bio or tagline."

# Social links (leave empty to hide)
linkedin: ""
github: ""
twitter: ""
twitter_handle: ""
substack: ""

# Home page
hero_title: "Your Name"
hero_subline: "Your tagline or one-liner bio."
about_teaser: "A brief paragraph about yourself for the home page."

# Thesis block — a 1-3 sentence POV statement shown on the home page.
# What do you specifically believe? What's your unique angle?
# Example: "Most teams are adopting AI tools. Few are rethinking how they build. I write about the difference."
thesis: ""

# Newsletter / subscription URL (Substack, Beehiiv, Buttondown, etc.)
# Leave empty to hide the subscribe prompt.
newsletter_url: ""

# Curated "Start Here" posts — list of post slugs to highlight as best-of.
# Slugs are the folder names under posts/YYYY/MM/ (e.g. "2024-01-15-post-title").
# Leave empty to show recent posts only.
featured_posts: []
#  - "2024-01-15-your-best-post"
#  - "2023-06-10-another-great-post"

# Speaking / consulting blurb shown on the About page (optional)
speaking_text: ""

# Topics — 3-5 named themes that organize your writing.
# Each topic maps to a set of tags (from post frontmatter).
# Generates /topics/ index and /topics/{slug}/ pages.
# Leave empty list to disable the Topics nav link.
topics: []
# topics:
#   - name: "AI in Engineering"
#     slug: ai-engineering
#     description: "What changes when AI becomes part of the team, not just a tool."
#     tags: [ai, llm, artificialintelligence, automation, copilot, genai]
#   - name: "Engineering Leadership"
#     slug: leadership
#     description: "Building teams, managing up, and making decisions under uncertainty."
#     tags: [leadership, management, engineering, cto, hiring, teambuilding]
#   - name: "Building Products"
#     slug: building
#     description: "The craft of shipping software — architecture, trade-offs, and speed."
#     tags: [software, product, startup, architecture, devops]

# Footer
footer_text: "Your Name · Your City"
